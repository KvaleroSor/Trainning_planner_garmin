generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ATHLETE
  COACH_PENDING
  COACH_VERIFIED
  ADMIN
}

enum CoachStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum RelationStatus {
  INVITED
  ACTIVE
  REMOVED
}

enum SportType {
  CYCLING
  RUNNING
  SWIMMING
  STRENGTH
  TRIATHLON
  MOBILITY
}

enum WorkoutStatus {
  PLANNED
  COMPLETED
  SKIPPED
  IMPORTED
}

enum WorkoutSource {
  MANUAL
  TEMPLATE
  GARMIN
  AI
}

enum AuditAction {
  COACH_VERIFIED
  COACH_REJECTED
  ATHLETE_LINKED
  ATHLETE_UNLINKED
  WORKOUT_CREATED
  WORKOUT_UPDATED
  WORKOUT_DELETED
  GARMIN_CONNECTED
  GARMIN_DISCONNECTED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(ATHLETE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  coachProfile   CoachProfile?
  athleteProfile AthleteProfile?
  auditEvents     AuditLog[] @relation("AuditActor")
  createdWorkouts Workout[] @relation("WorkoutCreatedBy")
  updatedWorkouts Workout[] @relation("WorkoutUpdatedBy")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CoachProfile {
  id             String      @id @default(cuid())
  userId         String      @unique
  status         CoachStatus @default(PENDING)
  organization   String?
  accreditation  String?
  bio            String?
  verifiedAt     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  athletes   CoachAthleteRelation[]
}

model AthleteProfile {
  id           String    @id @default(cuid())
  userId       String    @unique
  displayName  String
  primarySport SportType @default(CYCLING)
  objective    String
  weeklyHours  Int       @default(4)
  weightKg     Float?
  heightCm     Int?
  restingHr    Int?
  maxHr        Int?
  thresholdHr  Int?
  ftp          Int?
  fatigue      Int       @default(4)
  sleepQuality Int       @default(7)
  painNote     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  coaches          CoachAthleteRelation[]
  sportProfiles    SportProfile[]
  workouts         Workout[]
  garminActivities GarminActivity[]
  weeklyReviews    WeeklyReview[]
}

model CoachAthleteRelation {
  id        String         @id @default(cuid())
  coachId   String
  athleteId String
  status    RelationStatus @default(INVITED)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  coach   CoachProfile   @relation(fields: [coachId], references: [id], onDelete: Cascade)
  athlete AthleteProfile @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([coachId, athleteId])
}

model SportProfile {
  id         String    @id @default(cuid())
  athleteId  String
  sport      SportType
  metricName String?
  metricValue String?
  notes      String?

  athlete AthleteProfile @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([athleteId, sport])
}

model Workout {
  id             String        @id @default(cuid())
  athleteId      String
  title          String
  sport          SportType
  date           DateTime
  plannedMinutes Int
  actualMinutes  Int?
  intensity      String
  notes          String?
  status         WorkoutStatus @default(PLANNED)
  source         WorkoutSource @default(MANUAL)
  createdById    String?
  updatedById    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  athlete        AthleteProfile   @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  createdBy      User?            @relation("WorkoutCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy      User?            @relation("WorkoutUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  garminActivity GarminActivity?
  analyses       WorkoutAnalysis[]
}

model GarminActivity {
  id               String   @id @default(cuid())
  athleteId        String
  workoutId        String?  @unique
  providerActivityId String? @unique
  sport            SportType
  startedAt        DateTime
  durationMinutes  Int
  distanceMeters   Int?
  avgHr            Int?
  avgPower         Int?
  rawSummary       Json?
  createdAt        DateTime @default(now())

  athlete AthleteProfile @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  workout Workout?       @relation(fields: [workoutId], references: [id], onDelete: SetNull)
}

model WorkoutAnalysis {
  id           String   @id @default(cuid())
  workoutId    String
  compliance   Int
  signal       String
  athleteCopy  String
  coachCopy    String
  createdAt    DateTime @default(now())

  workout Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
}

model WeeklyReview {
  id               String   @id @default(cuid())
  athleteId        String
  weekStart        DateTime
  plannedMinutes   Int
  completedMinutes Int
  consistency      Int
  coachNotes       String?
  createdAt        DateTime @default(now())

  athlete AthleteProfile @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([athleteId, weekStart])
}

model AuditLog {
  id        String      @id @default(cuid())
  actorId   String?
  action    AuditAction
  targetId  String?
  metadata  Json?
  createdAt DateTime    @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
}
